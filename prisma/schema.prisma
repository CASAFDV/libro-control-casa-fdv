generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   // "SUPER_ADMIN" | "ADMIN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  adminCriteria AdminCriteria[]
}

model AdminCriteria {
  id         String   @id @default(cuid())
  adminId    String
  criteriaId String
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  criteria   Criteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)

  @@unique([adminId, criteriaId])
}

model Family {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  students  Student[]
}

model Student {
  id        String   @id @default(cuid())
  name      String
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  grades    Grade[]
  weeklyComments WeeklyComment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   // e.g., "2026-2027"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  weeks     Week[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Week {
  id             String      @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  weekNumber     Int
  startDate      DateTime
  label          String
  month          String      // e.g., "Abril 2026"
  grades         Grade[]
  weeklyComments WeeklyComment[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([academicYearId, weekNumber])
}

model Criteria {
  id             String           @id @default(cuid())
  name           String
  isActive       Boolean          @default(true)
  order          Int              @default(0)
  adminCriteria  AdminCriteria[]
  grades         Grade[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Grade {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  criteriaId  String
  criteria    Criteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  weekId      String
  week        Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  score       Float    @default(0)
  comment     String   @default("")
  gradedBy    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, criteriaId, weekId])
}

model WeeklyComment {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weekId    String
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  comment   String   @default("")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, weekId])
}
